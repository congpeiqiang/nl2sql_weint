# Vanna MCP SQL Server Configuration
# Copy this file to .env and update the values for your database.

# MCP transport: stdio | sse | http
NL2SQL_MCP_TRANSPORT=stdio
NL2SQL_MCP_HOST=0.0.0.0
NL2SQL_MCP_PORT=8000

# ================================================
# 数据库配置
# ================================================

# Database type. Supported values:
#   sqlite, duckdb, postgres, mysql, bigquery, snowflake,
#   mssql, oracle, clickhouse, hive, presto
DB_TYPE=sqlite

# SQLite / DuckDB
SQLITE_DB_PATH=/path/to/db.sqlite

# 通用关系型数据库字段（PostgreSQL / MySQL / ClickHouse / Hive 等）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=postgres
# DB_PASSWORD=secret

# 扩展配置：数据库特有参数，格式为 key=value,key2=value2
# 当字段与通用字段冲突时，以此处为准。
# DB_EXTRA_CONFIG=project_id=my-gcp-project,cred_file_path=/path/to/creds.json

# --- 各数据库完整示例 ---

# Example: DuckDB
# DB_TYPE=duckdb
# SQLITE_DB_PATH=/path/to/db.duckdb

# Example: PostgreSQL
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=postgres
# DB_PASSWORD=secret

# Example: MySQL
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_NAME=mydb
# DB_USER=root
# DB_PASSWORD=secret

# Example: BigQuery
# DB_TYPE=bigquery
# DB_EXTRA_CONFIG=project_id=my-gcp-project,cred_file_path=/path/to/creds.json

# Example: Snowflake
# DB_TYPE=snowflake
# DB_EXTRA_CONFIG=account=myaccount,username=user,database=MYDB
# DB_PASSWORD=secret

# Example: MSSQL
# DB_TYPE=mssql
# DB_EXTRA_CONFIG=odbc_conn_str=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=mydb;UID=user;PWD=secret

# Example: ClickHouse
# DB_TYPE=clickhouse
# DB_HOST=localhost
# DB_NAME=default
# DB_USER=default
# DB_PASSWORD=secret

# Example: Oracle
# DB_TYPE=oracle
# DB_EXTRA_CONFIG=dsn=localhost:1521/ORCL
# DB_USER=scott
# DB_PASSWORD=tiger

# Example: Hive
# DB_TYPE=hive
# DB_HOST=localhost
# DB_NAME=default
# DB_USER=hive
# DB_PASSWORD=secret

# Example: Presto
# DB_TYPE=presto
# DB_HOST=localhost
# DB_EXTRA_CONFIG=catalog=hive,schema=default
# DB_USER=presto
